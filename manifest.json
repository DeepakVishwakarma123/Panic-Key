{
  "manifest_version": 3,
  "name": "Panic Key",
  "version": "1.1",
  "action":{
    "default_popup": "./index.html"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type":"module"
  },
  "permissions":["storage","tabs","history","browsingData","storage"],
  "commands": {
    "panic-key": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y",
        "linux":"Ctrl+Shift+1"
      },
      "description": "Camoflage me"
    },
    "open":{
       "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y",
        "linux":"Ctrl+Shift+2"
      },
      "description": "opne me"
    }
  },
   "icons":{
      "16":"./icons/i16.png",
      "32":"./icons/i32.png",
      "48":"./icons/i48.png",
      "128":"./icons/i128.png"
    }
}